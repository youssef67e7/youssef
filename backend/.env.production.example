# ============================================
# PharmaWorld Backend - Production Environment
# ============================================

# Server
NODE_ENV=production
PORT=3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://Vercel-Admin-clinicDB:<db_password>@clinicdb.0qyfdxo.mongodb.net/clinicDB?appName=clinicDB&retryWrites=true&w=majority

# Redis (Upstash or Redis Cloud)
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# JWT
JWT_SECRET=your-64-character-random-secret-key-here
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-live-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@pharmaworld.com
SMTP_PASS=your-app-password

# CORS
CORS_ORIGINS=https://dashboard.pharmaworld.com,https://superadmin.pharmaworld.com

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
