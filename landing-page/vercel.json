{
  "version": 2,
  "name": "pharmaworld-landing",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "PharmaWorld.apk",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/PharmaWorld.apk", "headers": { "Content-Type": "application/vnd.android.package-archive", "Content-Disposition": "attachment; filename=\"PharmaWorld.apk\"" } },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
